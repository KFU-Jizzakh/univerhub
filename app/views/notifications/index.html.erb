<% content_for :title, t("views.shared.page_titles.notifications") %>

<% breadcrumbs do %>
  <%= breadcrumb t("breadcrumbs.notifications") %>
<% end %>

<div class="page-header mb-4 pb-3 border-bottom">
  <h2><%= t("views.notifications.page_title") %></h2>
</div>

<% if Current.user.notifications.unread.any? %>
  <div class="d-flex gap-2 my-3">
    <%= button_to t("views.notifications.mark_all_as_read"), mark_all_as_read_notifications_path, method: :patch, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<% if @notifications.any? %>
  <% @notifications.each do |notification| %>
    <%= render notification %>
  <% end %>

  <%== pagy_nav_html(@pagy) %>
<% else %>
  <%= render "shared/empty_state", icon: "bi-bell", message: t("views.shared.empty_state.no_notifications") %>
<% end %>
