<% content_for :title, t("views.shared.page_titles.password_recovery") %>

<div class="auth-container">
  <h2 class="mb-3"><%= t("views.shared.page_titles.password_recovery") %></h2>
  <p class="auth-subtitle text-muted"><%= t("views.shared.page_titles.password_recovery_subtitle") %></p>

  <% if flash[:alert] %>
    <div class="alert alert-danger"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with url: passwords_path do |form| %>
    <div class="mb-3">
      <%= form.label :email_address, t("views.shared.labels.email"), class: "form-label" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: t("views.shared.placeholders.email"), value: params[:email_address], class: "form-control" %>
    </div>

    <%= form.submit t("views.shared.buttons.send_instructions"), class: "btn btn-primary w-100" %>
  <% end %>

  <p class="auth-footer mt-3 text-muted"><%= link_to t("views.shared.buttons.back_to_login"), new_session_path %></p>
</div>
