<!DOCTYPE html>
<html lang="ru">
  <head>
    <title><%= content_for(:title) || "UniverHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="UniverHub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application.css", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="sidebar-toggle">
    <a href="#main-content" class="skip-link"><%= t("accessibility.skip_to_content") %></a>
    <% if authenticated? %>
      <nav class="navbar navbar-expand navbar-light bg-white border-bottom">
        <div class="container-fluid px-3">
          <ul class="navbar-nav">
            <li class="nav-item">
              <button class="btn btn-link nav-link p-0 me-2 sidebar-toggle"
                      data-action="sidebar-toggle#toggle"
                      data-sidebar-toggle-target="toggle"
                      aria-label="<%= t("navigation.toggle_sidebar") %>">
                <i class="bi bi-list fs-4"></i>
              </button>
            </li>
            <li class="nav-item">
              <%= link_to "UniverHub", root_path, class: "navbar-brand fw-bold text-primary text-decoration-none" %>
            </li>
          </ul>
          <ul class="navbar-nav">
            <li class="nav-item">
              <%= link_to notifications_path, class: "nav-link d-flex align-items-center gap-1" do %>
                <i class="bi bi-bell"></i>
                <span class="d-none d-md-inline"><%= t("navigation.notifications") %></span>
                <% count = current_user.notifications.unread.count %>
                <% if count > 0 %>
                   <span class="badge bg-danger rounded-pill" role="status"><%= count %></span>
                <% end %>
              <% end %>
            </li>
            <li class="nav-item dropdown">
               <button class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                      aria-label="<%= t("accessibility.user_menu") %>">
                <%= user_avatar(current_user, size: :navbar) %>
                <span class="d-none d-md-inline"><%= user_display(current_user) %></span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li>
                  <%= link_to profile_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                    <i class="bi bi-person"></i> <%= t("navigation.profile") %>
                  <% end %>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <%= button_to session_path, method: :delete, class: "dropdown-item d-flex align-items-center gap-2" do %>
                    <i class="bi bi-box-arrow-right"></i> <%= t("navigation.logout") %>
                  <% end %>
                </li>
              </ul>
            </li>
          </ul>
        </div>
      </nav>

      <div class="container-fluid">
        <div class="row">
          <aside class="app-sidebar col-lg-2 p-0" data-sidebar-toggle-target="sidebar">
            <nav>
              <div class="sidebar-section">
                <ul>
                  <li><%= link_to root_path, class: ("active" if request.path == "/") do %>
                    <i class="bi bi-house"></i> <%= t("navigation.home") %>
                  <% end %></li>
                </ul>
              </div>

              <div class="sidebar-section">
                <div class="sidebar-heading"><%= t("navigation.reports_section") %></div>
                <ul>
                  <li><%= sidebar_link t("navigation.all_reports"), reporting_reports_path, icon: "bi-file-earmark-text" %></li>
                  <% if policy(Reporting::ReportTemplate).create? %>
                    <li><%= sidebar_link t("navigation.templates"), reporting_report_templates_path, icon: "bi-layout-text-window-reverse" %></li>
                    <li><%= sidebar_link t("navigation.create_report"), new_reporting_report_path, exact: true, icon: "bi-plus-circle" %></li>
                  <% end %>
                  <% if policy([:reporting, :reporter]).index? %>
                    <li><%= sidebar_link t("navigation.reporters"), reporting_reporters_path, icon: "bi-people" %></li>
                  <% end %>
                </ul>
              </div>

              <% if policy(:activity_feed).index? %>
                <div class="sidebar-section">
                  <div class="sidebar-heading"><%= t("navigation.monitoring") %></div>
                  <ul>
                    <li><%= sidebar_link t("navigation.activity"), activity_feed_index_path, icon: "bi-clock-history" %></li>
                  </ul>
                </div>
              <% end %>

              <% if policy([:admin, User]).index? %>
                <div class="sidebar-section">
                  <div class="sidebar-heading"><%= t("navigation.administration") %></div>
                  <ul>
                    <li><%= sidebar_link t("navigation.users"), admin_users_path, icon: "bi-person-gear" %></li>
                  </ul>
                </div>
              <% end %>

               <% if policy(Dormitory::Building).index? %>
                 <div class="sidebar-section">
                   <div class="sidebar-heading"><%= t("navigation.dormitory") %></div>
                   <ul>
                     <li><%= sidebar_link t("navigation.dormitory_dashboard"), dormitory_dashboard_path, icon: "bi-speedometer2" %></li>
                     <li><%= sidebar_link t("navigation.buildings"), dormitory_buildings_path, icon: "bi-building" %></li>
                     <li><%= sidebar_link t("navigation.rooms"), dormitory_rooms_path, icon: "bi-door-open" %></li>
                     <li><%= sidebar_link t("navigation.residents"), dormitory_residents_path, icon: "bi-person-vcard" %></li>
                     <li><%= sidebar_link t("navigation.accommodations"), dormitory_accommodations_path, icon: "bi-key" %></li>
                      <% if policy(Dormitory::AcademicYear).index? %>
                        <li><%= sidebar_link t("navigation.dormitory_academic_years"), dormitory_academic_years_path, icon: "bi-calendar3" %></li>
                      <% end %>
                      <% if policy(Dormitory::BatchOperation).index? %>
                        <li><%= sidebar_link t("navigation.dormitory_batch_operations"), dormitory_batch_evictions_path, icon: "bi-list-task" %></li>
                      <% end %>
                   </ul>
                 </div>
               <% end %>
            </nav>
          </aside>

          <div class="sidebar-overlay" data-sidebar-toggle-target="overlay" data-action="click->sidebar-toggle#close" aria-hidden="true"></div>

          <main class="app-main col-lg-10 py-4" data-sidebar-toggle-target="main" id="main-content" tabindex="-1">
            <% if content_for?(:breadcrumbs) %>
              <nav class="breadcrumbs mb-3" aria-label="breadcrumbs">
                <ul>
                  <li><%= link_to t("breadcrumbs.home"), root_path %></li>
                  <%= yield :breadcrumbs %>
                </ul>
              </nav>
            <% end %>

            <div class="alert alert-warning mb-3" role="status">
              Система работает в тестовом режиме
            </div>

            <% if notice.present? %>
              <div class="alert alert-success" role="status"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="alert alert-danger" role="alert"><%= alert %></div>
            <% end %>

            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="container">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
