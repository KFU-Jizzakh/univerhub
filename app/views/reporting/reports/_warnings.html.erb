<% missing_attachments = report.report_items.select { |i| i.attachments_required? && !i.attachments.attached? } %>
<% not_all_graded = policy(report).grade? && !report.all_items_graded? %>

<% if missing_attachments.any? || not_all_graded %>
  <div class="alert alert-warning mb-4" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <ul class="mb-0 ps-3">
      <% if missing_attachments.any? %>
        <li><%= t("views.shared.hints.missing_attachments", items: missing_attachments.map(&:name).join(', ')) %></li>
      <% end %>
      <% if not_all_graded %>
        <li><%= t("views.shared.hints.all_items_graded") %></li>
      <% end %>
    </ul>
  </div>
<% end %>
