<tr id="<%= dom_id(report_template_item) %>">
  <td><%= report_template_item.position %></td>
  <td><%= report_template_item.name %></td>
  <td><%= report_template_item.description %></td>
  <td><%= report_template_item.max_grade || "—" %></td>
  <td><%= report_template_item.attachments_required? ? t("navigation.yes") : t("navigation.no") %></td>
  <% if policy(report_template_item.report_template).update? %>
    <td class="text-end">
      <div class="d-inline-flex gap-2">
        <%= link_to t("views.shared.actions.edit"), edit_reporting_report_template_report_template_item_path(report_template_item.report_template, report_template_item), class: "btn btn-sm btn-outline-secondary" %>
        <%= button_to t("views.shared.actions.delete"), reporting_report_template_report_template_item_path(report_template_item.report_template, report_template_item), method: :delete, data: { turbo_confirm: t("views.shared.confirm_dialogs.delete_item") }, class: "btn btn-sm btn-outline-danger" %>
      </div>
    </td>
  <% end %>
</tr>
