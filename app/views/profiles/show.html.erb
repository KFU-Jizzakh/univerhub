<% content_for :title, t("views.profiles.show.title") %>

<% breadcrumbs do %>
  <%= breadcrumb t("navigation.profile") %>
<% end %>

<div class="page-header mb-4 pb-3 border-bottom">
  <h2><i class="bi bi-person-circle"></i> <%= t("views.profiles.show.title") %></h2>
</div>

<div class="row">
  <div class="col-lg-6">
    <div class="info-grid">
      <div class="info-item">
        <span class="info-label"><%= t("views.profiles.show.full_name") %></span>
        <span class="info-value"><%= user_display(@user) %></span>
      </div>
      <div class="info-item">
        <span class="info-label"><%= t("views.profiles.show.email") %></span>
        <span class="info-value"><%= @user.email_address %></span>
      </div>
      <div class="info-item">
        <span class="info-label"><%= t("views.profiles.show.roles") %></span>
        <span class="info-value">
          <% @user.roles.each do |role| %>
            <span class="status-badge status-badge--published status-badge--sm"><%= role.name %></span>
          <% end %>
          <% if @user.roles.empty? %>—<% end %>
        </span>
      </div>
      <div class="info-item">
        <span class="info-label"><%= t("views.profiles.show.registered") %></span>
        <span class="info-value"><%= format_datetime(@user.created_at) %></span>
      </div>
    </div>

    <div class="mb-3">
      <%= user_avatar(@user, size: :show) %>
    </div>
  </div>
</div>
