<% content_for :title, t("views.dormitory.rooms.new_room") %>

<% breadcrumbs do %>
  <%= breadcrumb t("breadcrumbs.dormitory_rooms"), dormitory_rooms_path %>
  <%= breadcrumb t("views.shared.actions.create") %>
<% end %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <h1 class="h3 mb-0"><%= t("views.dormitory.rooms.new_room") %></h1>
</div>

<%= form_with(model: @room, url: dormitory_rooms_path, data: { controller: "room-number-suggest", room_number_suggest_url_value: suggest_number_dormitory_rooms_path }) do |f| %>
  <%= render "shared/form_errors", object: @room %>

  <div class="mb-3">
    <%= f.label :building_id, t("views.dormitory.rooms.building"), class: "form-label" %>
    <%= f.select :building_id,
          options_from_collection_for_select(@buildings, :id, :name, @room.building_id),
          { prompt: t("views.shared.placeholders.select_user") },
          { class: "form-select", required: true, data: { room_number_suggest_target: "building", action: "change->room-number-suggest#updateNumber" } } %>
  </div>

  <div class="mb-3">
    <%= f.label :floor, t("views.dormitory.rooms.floor"), class: "form-label" %>
    <%= f.number_field :floor, required: true, min: 1, class: "form-control",
          data: { room_number_suggest_target: "floor", action: "input->room-number-suggest#updateNumber" } %>
  </div>

  <div class="mb-3">
    <%= f.label :number, t("views.dormitory.rooms.room_number"), class: "form-label" %>
    <%= f.text_field :number, required: true, class: "form-control",
          data: { room_number_suggest_target: "number" } %>
  </div>

  <div class="mb-3">
    <%= f.label :capacity, t("views.dormitory.rooms.capacity"), class: "form-label" %>
    <%= f.number_field :capacity, required: true, min: 1, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :gender_restriction, t("views.dormitory.rooms.gender_restriction"), class: "form-label" %>
    <%= f.select :gender_restriction,
          options_for_select([
            [ t("views.dormitory.rooms.gender_none"), "" ],
            [ t("views.dormitory.rooms.gender_male"), "male" ],
            [ t("views.dormitory.rooms.gender_female"), "female" ]
          ], @room.gender_restriction),
          {}, class: "form-select" %>
  </div>

  <div class="d-flex gap-2 mb-3">
    <%= f.submit t("views.shared.actions.create"), class: "btn btn-primary" %>
    <%= link_to t("views.shared.actions.cancel"), dormitory_rooms_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
