<% content_for :title, t("views.dormitory.accommodations.show_title", name: @accommodation.resident.full_name) %>

<% breadcrumbs do %>
  <%= breadcrumb t("breadcrumbs.dormitory_accommodations"), dormitory_accommodations_path %>
  <%= breadcrumb @accommodation.resident.full_name %>
<% end %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <h1 class="h3 mb-0"><%= t("views.dormitory.accommodations.show_title", name: @accommodation.resident.full_name) %></h1>
  <%= status_badge(@accommodation.status) %>
</div>

<div class="row mb-4">
  <% if @accommodation.resident.photo.attached? %>
    <div class="col-md-2">
      <%= image_tag @accommodation.resident.photo, class: "img-thumbnail rounded avatar-xl" %>
    </div>
    <div class="col-md-10">
  <% else %>
    <div class="col-12">
  <% end %>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.residents.full_name") %></span>
          <span class="info-value"><%= link_to @accommodation.resident.full_name, dormitory_resident_path(@accommodation.resident) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.building") %></span>
          <span class="info-value"><%= link_to @accommodation.room.building.name, dormitory_building_path(@accommodation.room.building) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.room") %></span>
          <span class="info-value"><%= link_to @accommodation.room.number, dormitory_room_path(@accommodation.room) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.start_date") %></span>
          <span class="info-value"><%= l(@accommodation.start_date, format: :short) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.planned_end_date") %></span>
          <span class="info-value">
            <%= l(@accommodation.planned_end_date, format: :short) %>
            <% if @accommodation.overdue? %>
              <span class="badge bg-warning text-dark ms-1" title="<%= t('views.dormitory.accommodations.overdue_icon_title') %>"><i class="bi bi-exclamation-triangle"></i></span>
            <% end %>
          </span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.planned_duration") %></span>
          <span class="info-value"><%= t("views.dormitory.accommodations.days", count: @accommodation.planned_duration_days) %></span>
        </div>
        <% if @accommodation.actual_duration_days %>
          <div class="info-item">
            <span class="info-label"><%= t("views.dormitory.accommodations.actual_duration") %></span>
            <span class="info-value"><%= t("views.dormitory.accommodations.days", count: @accommodation.actual_duration_days) %></span>
          </div>
        <% end %>
        <% if @accommodation.comment.present? %>
          <div class="info-item">
            <span class="info-label"><%= t("views.dormitory.accommodations.comment") %></span>
            <span class="info-value"><%= @accommodation.comment %></span>
          </div>
        <% end %>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.audit.created_by") %></span>
          <span class="info-value"><%= created_by_info(@accommodation) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.audit.last_modified") %></span>
          <span class="info-value"><%= last_modified_by(@accommodation) %></span>
        </div>
      </div>
    </div>
</div>

<h5 class="mb-3"><%= t("views.dormitory.accommodations.section_documents") %></h5>
<div class="table-responsive mb-4">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th scope="col"><%= t("views.dormitory.accommodations.document") %></th>
        <th scope="col"><%= t("views.dormitory.accommodations.document_number") %></th>
        <th scope="col"><%= t("views.dormitory.accommodations.document_file") %></th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><i class="bi bi-file-earmark-text me-1"></i> <%= t("views.dormitory.accommodations.application") %></td>
        <td><%= @accommodation.application_number %></td>
        <td>
          <% if @accommodation.application_file.attached? %>
            <i class="bi <%= file_icon_class(@accommodation.application_file) %> me-1"></i>
            <%= link_to @accommodation.application_file.filename, url_for(@accommodation.application_file), target: "_blank" %>
            <span class="text-muted small">(<%= number_to_human_size(@accommodation.application_file.byte_size) %>)</span>
          <% else %>
            <span class="text-muted"><%= t("views.dormitory.accommodations.no_file") %></span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td><i class="bi bi-file-earmark-text me-1"></i> <%= t("views.dormitory.accommodations.contract") %></td>
        <td><%= @accommodation.contract_number %></td>
        <td>
          <% if @accommodation.contract_file.attached? %>
            <i class="bi <%= file_icon_class(@accommodation.contract_file) %> me-1"></i>
            <%= link_to @accommodation.contract_file.filename, url_for(@accommodation.contract_file), target: "_blank" %>
            <span class="text-muted small">(<%= number_to_human_size(@accommodation.contract_file.byte_size) %>)</span>
          <% else %>
            <span class="text-muted"><%= t("views.dormitory.accommodations.no_file") %></span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td><i class="bi bi-receipt me-1"></i> <%= t("views.dormitory.accommodations.receipt") %></td>
        <td>—</td>
        <td>
          <% if @accommodation.payment_receipt.attached? %>
            <i class="bi <%= file_icon_class(@accommodation.payment_receipt) %> me-1"></i>
            <%= link_to @accommodation.payment_receipt.filename, url_for(@accommodation.payment_receipt), target: "_blank" %>
            <span class="text-muted small">(<%= number_to_human_size(@accommodation.payment_receipt.byte_size) %>)</span>
          <% else %>
            <span class="text-muted"><%= t("views.dormitory.accommodations.no_file") %></span>
          <% end %>
        </td>
      </tr>
    </tbody>
  </table>
</div>

<%= render_audit_trail(@audit_events) %>

<div class="d-flex flex-wrap gap-2 my-3">
  <% if @accommodation.active? && policy(@accommodation).new_eviction? %>
    <%= link_to t("views.dormitory.accommodations.evict_button"), new_eviction_dormitory_accommodation_path(@accommodation), class: "btn btn-danger" %>
  <% end %>
  <% if @accommodation.active? && policy(@accommodation).new_transfer? %>
    <%= link_to t("views.dormitory.accommodations.transfer_button"), new_transfer_dormitory_accommodation_path(@accommodation), class: "btn btn-warning" %>
  <% end %>
  <% if policy(@accommodation).edit? %>
    <%= link_to t("views.shared.actions.edit"), edit_dormitory_accommodation_path(@accommodation), class: "btn btn-outline-secondary" %>
  <% end %>
  <%= link_to t("views.shared.actions.back"), dormitory_resident_path(@accommodation.resident), class: "btn btn-outline-secondary" %>
</div>
