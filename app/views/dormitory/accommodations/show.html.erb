<% content_for :title, t("views.dormitory.accommodations.show_title", name: @accommodation.resident.full_name) %>

<% breadcrumbs do %>
  <%= breadcrumb t("breadcrumbs.dormitory_accommodations"), dormitory_accommodations_path %>
  <%= breadcrumb @accommodation.resident.full_name %>
<% end %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <h1 class="h3 mb-0"><%= t("views.dormitory.accommodations.show_title", name: @accommodation.resident.full_name) %></h1>
  <%= status_badge(@accommodation.status) %>
</div>

<div class="row mb-4">
  <% if @accommodation.resident.photo.attached? %>
    <div class="col-md-2">
      <%= image_tag @accommodation.resident.photo, class: "img-thumbnail rounded avatar-xl" %>
    </div>
    <div class="col-md-10">
  <% else %>
    <div class="col-12">
  <% end %>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.residents.full_name") %></span>
          <span class="info-value"><%= link_to @accommodation.resident.full_name, dormitory_resident_path(@accommodation.resident) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.building") %></span>
          <span class="info-value"><%= link_to @accommodation.room.building.name, dormitory_building_path(@accommodation.room.building) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.room") %></span>
          <span class="info-value"><%= link_to @accommodation.room.number, dormitory_room_path(@accommodation.room) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.start_date") %></span>
          <span class="info-value"><%= l(@accommodation.start_date, format: :short) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.planned_end_date") %></span>
          <span class="info-value">
            <%= l(@accommodation.planned_end_date, format: :short) %>
            <% if @accommodation.overdue? %>
              <span class="badge bg-warning text-dark ms-1" title="<%= t('views.dormitory.accommodations.overdue_icon_title') %>"><i class="bi bi-exclamation-triangle"></i></span>
            <% end %>
          </span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.accommodations.planned_duration") %></span>
          <span class="info-value"><%= t("views.dormitory.accommodations.days", count: @accommodation.planned_duration_days) %></span>
        </div>
        <% if @accommodation.actual_duration_days %>
          <div class="info-item">
            <span class="info-label"><%= t("views.dormitory.accommodations.actual_duration") %></span>
            <span class="info-value"><%= t("views.dormitory.accommodations.days", count: @accommodation.actual_duration_days) %></span>
          </div>
        <% end %>
        <% if @accommodation.comment.present? %>
          <div class="info-item">
            <span class="info-label"><%= t("views.dormitory.accommodations.comment") %></span>
            <span class="info-value"><%= @accommodation.comment %></span>
          </div>
        <% end %>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.audit.created_by") %></span>
          <span class="info-value"><%= created_by_info(@accommodation) %></span>
        </div>
        <div class="info-item">
          <span class="info-label"><%= t("views.dormitory.audit.last_modified") %></span>
          <span class="info-value"><%= last_modified_by(@accommodation) %></span>
        </div>
      </div>
    </div>
</div>

<h5 class="mb-3"><%= t("views.dormitory.accommodations.section_documents") %></h5>
<div class="table-responsive mb-4">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th scope="col"><%= t("views.dormitory.accommodations.document") %></th>
        <th scope="col"><%= t("views.dormitory.accommodations.document_number") %></th>
        <th scope="col"><%= t("views.dormitory.accommodations.document_file") %></th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><i class="bi bi-file-earmark-text me-1"></i> <%= t("views.dormitory.accommodations.application") %></td>
        <td><%= @accommodation.application_number %></td>
        <td>
          <% if @accommodation.application_file.attached? %>
            <i class="bi <%= file_icon_class(@accommodation.application_file) %> me-1"></i>
            <%= link_to @accommodation.application_file.filename, url_for(@accommodation.application_file), target: "_blank" %>
            <span class="text-muted small">(<%= number_to_human_size(@accommodation.application_file.byte_size) %>)</span>
          <% else %>
            <span class="text-muted"><%= t("views.dormitory.accommodations.no_file") %></span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td><i class="bi bi-file-earmark-text me-1"></i> <%= t("views.dormitory.accommodations.contract") %></td>
        <td><%= @accommodation.contract_number %></td>
        <td>
          <% if @accommodation.contract_file.attached? %>
            <i class="bi <%= file_icon_class(@accommodation.contract_file) %> me-1"></i>
            <%= link_to @accommodation.contract_file.filename, url_for(@accommodation.contract_file), target: "_blank" %>
            <span class="text-muted small">(<%= number_to_human_size(@accommodation.contract_file.byte_size) %>)</span>
          <% else %>
            <span class="text-muted"><%= t("views.dormitory.accommodations.no_file") %></span>
          <% end %>
        </td>
      </tr>

    </tbody>
  </table>
</div>

<h5 class="mb-3"><%= t("views.dormitory.accommodations.section_payments") %></h5>
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card text-center p-3 shadow-sm">
      <div class="text-muted small"><%= t("views.dormitory.accommodations.required_amount") %></div>
      <div class="h5 mb-0"><%= number_to_currency(@accommodation.required_amount, unit: "", separator: ",", delimiter: " ", precision: 2) %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-center p-3 shadow-sm">
      <div class="text-muted small"><%= t("views.dormitory.accommodations.total_paid") %></div>
      <div class="h5 mb-0"><%= number_to_currency(@accommodation.total_paid, unit: "", separator: ",", delimiter: " ", precision: 2) %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-center p-3 shadow-sm">
      <div class="text-muted small"><%= t("views.dormitory.accommodations.balance") %></div>
      <div class="h5 mb-0 <%= @accommodation.balance >= 0 ? 'text-success' : 'text-danger' %>">
        <%= number_to_currency(@accommodation.balance, unit: "", separator: ",", delimiter: " ", precision: 2) %>
      </div>
    </div>
  </div>
</div>

<% if @accommodation.receipts.any? %>
  <div class="mb-3">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th scope="col"><%= t("views.dormitory.receipts.paid_at") %></th>
          <th scope="col"><%= t("views.dormitory.receipts.amount") %></th>
          <th scope="col"><%= t("views.dormitory.accommodations.document_file") %></th>
          <th scope="col"><%= t("views.dormitory.accommodations.comment") %></th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        <% @accommodation.receipts.ordered.each do |receipt| %>
          <tr>
            <td><%= l(receipt.paid_at, format: :short) %></td>
            <td><%= number_to_currency(receipt.amount, unit: "", separator: ",", delimiter: " ", precision: 2) %></td>
            <td>
              <% if receipt.attachment.attached? %>
                <i class="bi <%= file_icon_class(receipt.attachment) %> me-1"></i>
                <%= link_to receipt.attachment.filename, url_for(receipt.attachment), target: "_blank" %>
                <span class="text-muted small">(<%= number_to_human_size(receipt.attachment.byte_size) %>)</span>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= receipt.comment.presence || "—" %></td>
            <td>
              <% if @accommodation.active? && (policy(receipt).edit? || policy(receipt).destroy?) %>
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <% if policy(receipt).edit? %>
                      <li>
                        <%= link_to edit_dormitory_accommodation_receipt_path(@accommodation, receipt), class: "dropdown-item" do %>
                          <i class="bi bi-pencil me-1"></i> <%= t("views.shared.actions.edit") %>
                        <% end %>
                      </li>
                    <% end %>
                    <% if policy(receipt).destroy? %>
                      <% if policy(receipt).edit? %>
                        <li><hr class="dropdown-divider"></li>
                      <% end %>
                      <li>
                        <%= button_to dormitory_accommodation_receipt_path(@accommodation, receipt),
                              method: :delete, class: "dropdown-item text-danger",
                              form: { data: { turbo_confirm: t("views.dormitory.receipts.confirm_delete") } } do %>
                          <i class="bi bi-trash me-1"></i> <%= t("views.shared.actions.delete") %>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted mb-3"><%= t("views.dormitory.accommodations.no_receipts") %></p>
<% end %>

<div class="d-flex flex-wrap gap-2 mb-4">
  <% if @accommodation.active? && policy(Dormitory::Receipt).new? %>
    <%= link_to new_dormitory_accommodation_receipt_path(@accommodation), class: "btn btn-outline-primary" do %>
      <i class="bi bi-plus-circle"></i> <%= t("views.dormitory.accommodations.add_receipt") %>
    <% end %>
  <% end %>
  <% if @accommodation.active? && @accommodation.balance < 0 && policy(Dormitory::Receipt).new? %>
    <%= link_to new_dormitory_accommodation_receipt_path(@accommodation, amount: @accommodation.balance.abs), class: "btn btn-success" do %>
      <i class="bi bi-cash"></i> <%= t("views.dormitory.accommodations.pay_remaining") %>
    <% end %>
  <% end %>
</div>

<%= render_audit_trail(@audit_events) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 my-3">
  <%= link_to dormitory_resident_path(@accommodation.resident), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-arrow-left me-1"></i> <%= t("views.shared.actions.back") %>
  <% end %>

  <div class="d-flex gap-2">
    <% if @accommodation.active? && policy(@accommodation).new_transfer? %>
      <%= link_to new_transfer_dormitory_accommodation_path(@accommodation), class: "btn btn-warning" do %>
        <i class="bi bi-arrow-left-right me-1"></i> <%= t("views.dormitory.accommodations.transfer_button") %>
      <% end %>
    <% end %>
    <% if @accommodation.active? && policy(@accommodation).new_eviction? %>
      <%= link_to new_eviction_dormitory_accommodation_path(@accommodation), class: "btn btn-danger" do %>
        <i class="bi bi-door-open me-1"></i> <%= t("views.dormitory.accommodations.evict_button") %>
      <% end %>
    <% end %>
    <% if policy(@accommodation).edit? %>
      <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-three-dots-vertical"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li>
            <%= link_to edit_dormitory_accommodation_path(@accommodation), class: "dropdown-item" do %>
              <i class="bi bi-pencil me-1"></i> <%= t("views.shared.actions.edit") %>
            <% end %>
          </li>
        </ul>
      </div>
    <% end %>
  </div>
</div>
